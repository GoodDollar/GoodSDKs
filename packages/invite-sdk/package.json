{
  "name": "@goodsdks/invite-sdk",
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "build": "tsup --clean",
    "prepack": "yarn build",
    "dev": "tsc --watch",
    "bump": "yarn version patch && yarn build && git add package.json && git commit -m \"version bump\"",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@vitest/ui": "^4.0.18",
    "tsup": "^8.4.0",
    "typescript": "latest",
    "viem": "latest",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "viem": "*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "GoodDollar InvitesV2 SDK — typed viem-based wrapper for invite codes, levels, and G$ bounties"
}
